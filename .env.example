# Supabase — from https://supabase.com/dashboard → your project → Settings → API Keys
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Resend — from https://resend.com/api-keys and https://resend.com/domains
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=PlainCost Insights <hello@plaincost.ai>

# Waitlist admin — choose a strong password; server-only Supabase key for reads
WAITLIST_ADMIN_SECRET=choose-a-long-random-password
SUPABASE_SECRET_KEY=sb_secret_...

# PlainCost AWS account — used to assume customer IAM roles
PLAINCOST_AWS_ACCESS_KEY_ID=AKIA...
PLAINCOST_AWS_SECRET_ACCESS_KEY=...
PLAINCOST_AWS_ACCOUNT_ID=123456789012
NEXT_PUBLIC_PLAINCOST_AWS_ACCOUNT_ID=123456789012